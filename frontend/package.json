{
  "name": "zerodelay",
  "version": "0.1.0",
  "private": true,
  "author": "ZeroDelay",
  "description": "Hands-free, offline voice guidance for technicians.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.zerodelay.app",
    "productName": "ZeroDelay",
    "files": ["electron/**/*", "out/**/*"],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "ZeroDelay needs microphone access for hands-free voice guidance."
      }
    }
  }
}
